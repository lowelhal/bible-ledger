{
  "openapi": "3.1.0",
  "info": {
    "title": "Bible Ledger API",
    "version": "1.3.0",
    "description": "A high-precision, event-sourced spiritual ledger with source attribution, tags, and passage intersection logic."
  },
  "servers": [
    { "url": "https://api.bibleledger.app/v1", "description": "Production Server" }
  ],
  "paths": {
    "/ledger-entries": {
      "get": {
        "summary": "Retrieve ledger entries with date, passage, and tag filters.",
        "parameters": [
          { "name": "user_id", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "start_date", "in": "query", "schema": { "type": "string", "format": "date-time" }, "description": "Start of timeframe." },
          { "name": "end_date", "in": "query", "schema": { "type": "string", "format": "date-time" }, "description": "End of timeframe." },
          { "name": "book", "in": "query", "schema": { "type": "string" }, "description": "Filter by Bible book name." },
          { "name": "chapter", "in": "query", "schema": { "type": "integer" } },
          { "name": "tags", "in": "query", "schema": { "type": "array", "items": { "type": "string" } }, "explode": true, "description": "Filter by tags (e.g., 'Devotional')." }
        ],
        "responses": {
          "200": { "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/LedgerEntry" } } } } }
        }
      },
      "post": { 
        "summary": "Append a reading event (No PUT/Update supported to maintain ledger integrity).",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LedgerEntry" } } } }
      }
    },
    "/notes": {
      "get": { 
        "summary": "Retrieve user notes with passage and tag filtering.",
        "parameters": [
          { "name": "user_id", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "book", "in": "query", "schema": { "type": "string" } },
          { "name": "tags", "in": "query", "schema": { "type": "array", "items": { "type": "string" } }, "explode": true }
        ]
      },
      "post": { "summary": "Add a new note to a passage range." },
      "put": { "summary": "Update note content or tags." },
      "delete": { "summary": "Remove a note." }
    },
    "/highlights": {
      "get": { 
        "summary": "Retrieve highlights (supports overlaps).",
        "parameters": [
          { "name": "user_id", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "book", "in": "query", "schema": { "type": "string" } }
        ]
      },
      "post": { "summary": "Record a new highlight (Overlapping passages allowed)." },
      "delete": { "summary": "Remove a specific highlight by ID." }
    },
    "/stats/summary": {
      "get": {
        "summary": "Retrieve hierarchical completion stats and achievement badges.",
        "parameters": [{ "name": "user_id", "in": "query", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StatsSummary" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Source": {
        "type": "string",
        "enum": ["SYSTEM_AUTO", "USER_APP", "USER_WEB", "EXTERNAL_RSS", "EXTERNAL_ICAL", "API_INTEGRATION"]
      },
      "Passage": {
        "type": "object",
        "properties": {
          "book": { "type": "string" },
          "chapter": { "type": "integer" },
          "start_verse": { "type": "integer" },
          "end_verse": { "type": "integer" },
          "verse_ids": { "type": "array", "items": { "type": "string" }, "description": "For non-contiguous tracking." }
        },
        "required": ["book", "chapter", "start_verse", "end_verse"]
      },
      "LedgerEntry": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "user_id": { "type": "string" },
          "status": { "type": "string", "enum": ["PENDING", "CONFIRMED"] },
          "source": { "$ref": "#/components/schemas/Source" },
          "start_time": { "type": "string", "format": "date-time" },
          "end_time": { "type": "string", "format": "date-time" },
          "passage": { "$ref": "#/components/schemas/Passage" },
          "translation_id": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" }, "example": ["Devotional", "Church"] }
        },
        "required": ["user_id", "status", "passage", "source"]
      },
      "Note": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "user_id": { "type": "string" },
          "source": { "$ref": "#/components/schemas/Source" },
          "passage": { "$ref": "#/components/schemas/Passage" },
          "content": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Highlight": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "user_id": { "type": "string" },
          "passage": { "$ref": "#/components/schemas/Passage" },
          "color_hex": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "source": { "$ref": "#/components/schemas/Source" }
        }
      },
      "StatsSummary": {
        "type": "object",
        "properties": {
          "completion": {
            "type": "object",
            "properties": {
              "total_bible": { "type": "number" },
              "old_testament": { "$ref": "#/components/schemas/GroupStat" },
              "new_testament": { "$ref": "#/components/schemas/GroupStat" }
            }
          },
          "achievements": { "type": "array", "items": { "$ref": "#/components/schemas/Badge" } }
        }
      },
      "GroupStat": {
        "type": "object",
        "properties": {
          "percent": { "type": "number" },
          "sub_groups": {
            "type": "object",
            "properties": {
              "pentateuch": { "type": "number" },
              "history": { "type": "number" },
              "poetry_wisdom": { "type": "number" },
              "major_prophets": { "type": "number" },
              "minor_prophets": { "type": "number" },
              "gospels": { "type": "number" },
              "acts": { "type": "number" },
              "pauline_epistles": { "type": "number" },
              "general_epistles": { "type": "number" },
              "revelation": { "type": "number" }
            }
          }
        }
      },
      "Badge": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "earned": { "type": "boolean" },
          "earned_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}