# ─── Backend Environment Variables ────────────────────────────────────────────
#
# For Render: set these in the Render dashboard Environment section
# For Supabase DB: get connection string from Supabase Dashboard → Settings → Database
#

# Database (Supabase connection string)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Server
PORT=3000

# Auth
BETTER_AUTH_URL=https://your-frontend-domain.vercel.app
BETTER_AUTH_SECRET=<generate with: openssl rand -base64 32>

# Google OAuth
GOOGLE_CLIENT_ID=<from Google Cloud Console>
GOOGLE_CLIENT_SECRET=<from Google Cloud Console>

# YouVersion API
YOUVERSION_API_KEY=<your-youversion-api-key>
