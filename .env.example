# ─── Deployment Environment Variables ─────────────────────────────────────────
#
# Copy this file to .env and fill in the values for each environment.
#
# BACKEND (.env for NestJS on Render)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:<password>@<host>:5432/<db>?schema=public"
PORT=3000
BETTER_AUTH_URL=https://your-frontend-domain.vercel.app
BETTER_AUTH_SECRET=<generate with: openssl rand -base64 32>
GOOGLE_CLIENT_ID=<from Google Cloud Console>
GOOGLE_CLIENT_SECRET=<from Google Cloud Console>

# FRONTEND (.env.local for Next.js on Vercel)
# ─────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://your-backend-domain.onrender.com/v1
